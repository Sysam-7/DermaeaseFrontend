# Copy to .env.local (or .env) and adjust.

# Google Sign-In (One Tap / GSI button) — same Client ID as in Google Cloud
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend base URL for production builds / API calls (no trailing slash)
VITE_API_URL=http://localhost:5000

# Vite dev proxy: where Express listens. If your backend .env has PORT=3000, set:
# VITE_PROXY_TARGET=http://localhost:3000
VITE_PROXY_TARGET=http://localhost:5000
